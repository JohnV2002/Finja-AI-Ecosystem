# ======================================================================
#          Finja Weather API – Environment Variables
# ======================================================================
#
#   Project: Finja - Twitch Interactivity Suite
#   Module:  finja-weather
#   Author:  J. Apps (JohnV2002 / Sodakiller1)
#   Version: 1.0.0
#
# ----------------------------------------------------------------------
#
#   Copy this file to .env and adjust the settings below.
#
# ======================================================================

# Shared bearer token Finja uses to call this service. Generate with generate_token.py.
BEARER_TOKEN=change-me

# Active provider: open-meteo (default, free, no key) | google (needs setup below).
WEATHER_PROVIDER=open-meteo

# Only needed when WEATHER_PROVIDER=google (GCP billing account required, check EEA/DE terms).
GOOGLE_WEATHER_API_KEY=

# Logging: INFO (default) or DEBUG for verbose `docker logs`.
LOG_LEVEL=INFO

# Location cache (shared per rounded coordinate, NOT per user) — saves paid API calls.
WEATHER_CACHE_CURRENT_TTL_S=600     # current weather cached 10 min
WEATHER_CACHE_FORECAST_TTL_S=3600   # forecast cached 1 hour
WEATHER_CACHE_POLLEN_TTL_S=10800    # pollen cached 3 hours (daily data)
WEATHER_CACHE_AQ_TTL_S=1800         # air quality cached 30 min
WEATHER_CACHE_PRECISION=2           # round lat/lon to 2 decimals (~1.1 km grid)

# Pollen + Air Quality endpoints are Google-only (use GOOGLE_WEATHER_API_KEY above).
