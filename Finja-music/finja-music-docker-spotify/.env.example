# Finja Music Docker Spotify API - environment example.
# Copy to private/.env and fill in your real values (private/ is never
# synced or committed).
#
# NOTE: These are the exact variable names app.py reads via os.getenv() --
# a placeholder .env shipped on GitHub previously used CLIENT_ID/CLIENT_SECRET
# (no SPOTIFY_ prefix, no refresh token), which would silently do nothing
# since app.py never reads those names.

SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
SPOTIFY_REFRESH_TOKEN=your-spotify-refresh-token
