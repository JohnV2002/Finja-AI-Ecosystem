# Secrets — NEVER commit!
private/
.env
# Unused by app.py (only config_min.json is read) but still holds a real
# Spotify client id/secret/refresh_token in Production -- never commit.
config.json

# Real accumulated runtime data — NOT meant to be pushed. GitHub tracks
# small SEED/stub versions of these on purpose (fresh-clone starting
# state). NOTE: because these are already tracked in git with the small
# stub content, this does NOT stop a future commit from overwriting them
# -- when syncing, exclude these paths from the copy entirely.
Memory/memory.json
Memory/contexts.json
Memory/reactions.json
SongsDB/songs_kb.json

# Local-only runtime state and caches — never synced/committed
Memory/game_state.txt
cache/
SongsDB/backups/
SongsDB/.enrich_progress.json
SongsDB/fertige_bpm_keys.json
Nowplaying/*.txt

# Editor/tool config that shouldn't leak from Production
.claude/
.vscode/
.idea/

# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/
venv/
.venv/

# Test coverage artifacts (regenerated by `pytest --cov`, never commit)
.coverage
coverage.xml
htmlcov/
