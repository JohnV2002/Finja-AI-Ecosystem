# Secrets — NEVER commit! (config/config_spotify.json is loaded from a
# hardcoded path -- CONFIG_DIR = SCRIPT_DIR / "config" in webserver.py --
# so it can't be moved into private/ the way youtube/instagram's cookies
# were. Protection is gitignore + sync discipline only: never overwrite
# GitHub's safe placeholder with Production's real file.)
.env
config/config_spotify.json

# Real accumulated runtime data — NOT meant to be pushed. GitHub tracks
# small SEED/stub versions of these on purpose (fresh-clone starting
# state); Production's real files are 1000x+ bigger and personal.
# NOTE: because these are already tracked in git with the small stub
# content, adding them here does NOT stop a future commit from
# overwriting them -- this only blocks NEW files. When syncing, exclude
# these four paths from the copy entirely; keep GitHub's stub as-is.
Memory/memory.json
Memory/contexts.json
Memory/reactions.json
SongsDB/songs_kb.json

# Local-only state and caches — never synced/committed
Memory/blocklist.json
Memory/whitelist.json
Memory/game_state.txt
cache/
logs/
missingsongs/
SongsDB/backups/
exports/
.finja_server.lock

# Python
__pycache__/
*.pyc
.pytest_cache/

# Test coverage artifacts (regenerated by `pytest --cov`, never commit)
.coverage
coverage.xml
htmlcov/
