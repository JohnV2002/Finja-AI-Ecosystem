{
  "name": "glorpo-lang",
  "displayName": "Glorpo Language",
  "description": "Syntax highlighting for Glorpo (.glp) - Glorpo is pain.",
  "version": "1.0.0",
  "engines": { "vscode": "^1.70.0" },
  "categories": ["Programming Languages"],
  "contributes": {
    "languages": [{
      "id": "glorpo",
      "aliases": ["Glorpo", "glorpo"],
      "extensions": [".glp"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "glorpo",
      "scopeName": "source.glorpo",
      "path": "./syntaxes/glorpo.tmLanguage.json"
    }]
  }
}
