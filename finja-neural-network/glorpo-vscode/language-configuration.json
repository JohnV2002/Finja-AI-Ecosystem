{
  "comments": { "lineComment": "#" },
  "brackets": [["(", ")"], ["[", "]"], ["{", "}"]],
  "autoClosingPairs": [
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "{", "close": "}" },
    { "open": "\"", "close": "\"" },
    { "open": "'", "close": "'" }
  ],
  "surroundingPairs": [
    ["(", ")"], ["[", "]"], ["{", "}"],
    ["\"", "\""], ["'", "'"]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(gloo|glorpkin|glorb|glorbelif|glorpelse|glorpach|glorploop|glorptry|glorpcatch|glorpalways|glorpwith)\\b.*:\\s*$",
    "decreaseIndentPattern": "^\\s*(glorpelse|glorbelif|glorpcatch|glorpalways)\\b"
  }
}
