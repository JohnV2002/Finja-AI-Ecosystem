# Glorpo Front drop-in
# Put this file next to glorpo.php, glorpo.css, glorpo.js and your .html files.

RewriteEngine On

# Glorpo core files are served directly.
RewriteRule ^(?:glorpo\.php|glorpo\.css|glorpo\.js)$ - [L]

# Normal assets are served directly.
RewriteRule \.(?:css|js|mjs|json|xml|txt|ico|png|jpe?g|gif|webp|svg|avif|mp4|webm|mp3|wav|ogg|woff2?|ttf|eot|pdf|zip)$ - [L,NC]

# Root request: if index.html/index.htm exists, show it through Glorpo.
RewriteCond %{DOCUMENT_ROOT}/index.html -f
RewriteRule ^$ glorpo.php?f=index.html [QSA,L]
RewriteCond %{DOCUMENT_ROOT}/index.htm -f
RewriteRule ^$ glorpo.php?f=index.htm [QSA,L]

# Directory request: /folder/ -> /folder/index.html through Glorpo.
RewriteCond %{REQUEST_FILENAME} -d
RewriteCond %{REQUEST_FILENAME}/index.html -f
RewriteRule ^(.+)/$ glorpo.php?f=$1/index.html [QSA,L]
RewriteCond %{REQUEST_FILENAME} -d
RewriteCond %{REQUEST_FILENAME}/index.htm -f
RewriteRule ^(.+)/$ glorpo.php?f=$1/index.htm [QSA,L]

# Existing .html/.htm requests go through glorpo.php.
RewriteCond %{REQUEST_FILENAME} -f
RewriteCond %{REQUEST_FILENAME} \.html?$ [NC]
RewriteRule ^(.+\.html?)$ glorpo.php?f=$1 [QSA,L]
