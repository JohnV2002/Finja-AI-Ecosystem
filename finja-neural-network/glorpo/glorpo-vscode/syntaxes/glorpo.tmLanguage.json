{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Glorpo",
  "scopeName": "source.glorpo",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords-error" },
    { "include": "#keywords-control" },
    { "include": "#keywords-define" },
    { "include": "#keywords-values" },
    { "include": "#keywords-logic" },
    { "include": "#keywords-import" },
    { "include": "#keywords-scope" },
    { "include": "#builtins" },
    { "include": "#dunder" },
    { "include": "#function-call" },
    { "include": "#operators" }
  ],
  "repository": {

    "comments": {
      "match": "#.*$",
      "name": "comment.line.number-sign.glorpo"
    },

    "strings": {
      "patterns": [
        {
          "comment": "Triple double-quote - all f-string prefix variants (f, F, rf, fr, Rf, fR, RF, FR, ...)",
          "begin": "(?:[fFrRbBuU][fFrRbBuU]?)?\"\"\"",
          "end": "\"\"\"",
          "name": "string.quoted.double.block.glorpo",
          "patterns": [
            { "match": "\\\\.", "name": "constant.character.escape.glorpo" },
            { "match": "\\{[^}]*\\}", "name": "constant.other.placeholder.glorpo" }
          ]
        },
        {
          "comment": "Triple single-quote",
          "begin": "(?:[fFrRbBuU][fFrRbBuU]?)?'''",
          "end": "'''",
          "name": "string.quoted.single.block.glorpo",
          "patterns": [
            { "match": "\\\\.", "name": "constant.character.escape.glorpo" },
            { "match": "\\{[^}]*\\}", "name": "constant.other.placeholder.glorpo" }
          ]
        },
        {
          "comment": "Single double-quote",
          "begin": "(?:[fFrRbBuU][fFrRbBuU]?)?\"",
          "end": "\"",
          "name": "string.quoted.double.glorpo",
          "patterns": [
            { "match": "\\\\.", "name": "constant.character.escape.glorpo" },
            { "match": "\\{[^}]*\\}", "name": "constant.other.placeholder.glorpo" }
          ]
        },
        {
          "comment": "Single single-quote",
          "begin": "(?:[fFrRbBuU][fFrRbBuU]?)?'",
          "end": "'",
          "name": "string.quoted.single.glorpo",
          "patterns": [
            { "match": "\\\\.", "name": "constant.character.escape.glorpo" },
            { "match": "\\{[^}]*\\}", "name": "constant.other.placeholder.glorpo" }
          ]
        }
      ]
    },

    "numbers": {
      "match": "\\b(0x[0-9a-fA-F]+|0b[01]+|0o[0-7]+|[0-9]+(\\.[0-9]+)?([eE][+-]?[0-9]+)?)\\b",
      "name": "constant.numeric.glorpo"
    },

    "keywords-error": {
      "comment": "Glorpo is pain. - red, always.",
      "match": "\\b(glorptry|glorpcatch|glorpalways|glorpyeet|glorpswear)\\b",
      "name": "keyword.control.exception.glorpo"
    },

    "keywords-control": {
      "match": "\\b(glorb|glorbelif|glorpelse|glorpach|glorploop|glorpsnap|glorpskip|glorpnull|glorpcheck|glorpwhen)\\b",
      "name": "keyword.control.glorpo"
    },

    "keywords-define": {
      "match": "\\b(gloo|glorpback|glorpkin|glorbda|glorpgive|glorpfast|glorpwait)\\b",
      "name": "keyword.other.glorpo"
    },

    "keywords-values": {
      "match": "\\b(glorpyes|glorpno|glorpvoid|glorpnotyet)\\b",
      "name": "constant.language.glorpo"
    },

    "keywords-logic": {
      "match": "\\b(glorpand|glorpor|glorpnot|glorpis|glorpin)\\b",
      "name": "keyword.operator.logical.glorpo"
    },

    "keywords-import": {
      "match": "\\b(glorpget|glorpfrom|glorpas)\\b",
      "name": "keyword.control.import.glorpo"
    },

    "keywords-scope": {
      "match": "\\b(glorpwide|glorpreach|glorpbye|glorpwith)\\b",
      "name": "keyword.other.scope.glorpo"
    },

    "builtins": {
      "comment": "All glorpo builtins - synced with GLORPO_DICT in glorpo.py",
      "match": "\\b(glorp|glorpask|glorpshow|glorpfmt|glorpopen|glorpnum|glorptext|glorpfloat|glorpbool|glorplist|glorpmap|glorpbag|glorptuple|glorpfrozen|glorpbytes|glorpcomplex|glorpslice|glorptype|glorpthing|glorpsize|glorpid|glorphash|glorplook|glorpvars|glorpcall|glorpisa|glorpkidof|glorphas|glorpgrab|glorpset|glorpdrop|glorpsuper|glorpprop|glorpstatic|glorpclassy|glorprange|glorpcount|glorpzip|glorpmorph|glorpsift|glorpsort|glorpflip|glorpwalk|glorpnext|glorpabs|glorpsmol|glorpchonk|glorpsum|glorpround|glorppow|glorpdivmod|glorphex|glorpoct|glorpchr|glorpord|glorpbin|glorpany|glorpall|glorpchop|glorptrim|glorpswap|glorpscream|glorpwhisper|glorpbegin|glorpend|glorpseek|glorptally|glorpwhere|glorpglue|glorpshove|glorpyoink|glorpkeys|glorpvals|glorpstuff|glorpself)\\b",
      "name": "support.function.builtin.glorpo"
    },

    "dunder": {
      "comment": "All glorpo magic/dunder names - synced with GLORPO_DICT in glorpo.py",
      "match": "__(glorpbirth|glorpface|glorpmirror|glorpsize|glorpwalk|glorpstep|glorpcome|glorpleave|glorpdo|glorpgrab|glorpput|glorpzap|glorpwithin|glorpname|glorpmain|glorplist|glorpslots|glorpdoc|glorpkind|glorpdata)__",
      "name": "support.function.magic.glorpo"
    },

    "function-call": {
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
      "name": "entity.name.function.glorpo"
    },

    "operators": {
      "match": "(==|!=|<=|>=|<|>|\\+|-|\\*|/|%|\\*\\*|//|=|\\+=|-=|\\*=|/=)",
      "name": "keyword.operator.glorpo"
    }
  }
}
