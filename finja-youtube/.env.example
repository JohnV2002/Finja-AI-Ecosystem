# ======================================================================
#          Finja YouTube Shorts – Environment Variables
# ======================================================================
#
#   Copy this file as .env and fill in your values:
#     cp .env.example .env
#
#   ProtonVPN OpenVPN credentials can be found at:
#   https://account.protonvpn.com/account#openvpn
#
#   WARNING: These are NOT your normal ProtonVPN login credentials!
#            Look for "OpenVPN / IKEv2 username" on the page.
#
# ======================================================================

# ProtonVPN OpenVPN Credentials
PROTON_USER=
PROTON_PASS=

# VPN Server Country (default: Netherlands)
# Options: Netherlands, Germany, Switzerland, Sweden, etc.
VPN_COUNTRY=Netherlands

# ==========================================
# Application Configuration
# ==========================================

# ---- YouTube Config ----
YOUTUBE_TARGET_URL=https://www.youtube.com/shorts

# ---- Chrome Settings ----
CHROME_PORT=9222
MOBILE_UA="Mozilla/5.0 (Linux; Android 13; SM-S908B) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Mobile Safari/537.36"

# ---- Finja Brain & Discord (for Autopilot) ----
FINJA_BRAIN_URL=http://localhost:8051
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
