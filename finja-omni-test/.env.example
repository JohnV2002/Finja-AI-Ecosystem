# Finja Omni Test Environment Variables
# Copy this file to .env and fill in your values

# OpenRouter API Key for Cloud Models (Optional if using only local models)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# LLM for Chat/Reactions (e.g., in quatsch.py)
CHAT_MODEL=google/gemma-4-31b-it

# Vision Language Model for local scene understanding via Ollama (in see.py)
LOCAL_VLM=minicpm-v4.6:latest

# Vision Language Model for cloud scene understanding via OpenRouter (in see.py)
OPENROUTER_VLM=qwen/qwen3-vl-8b-instruct
