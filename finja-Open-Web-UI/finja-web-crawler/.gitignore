# Secrets — NEVER commit! (.env holds the real BEARER_TOKEN once filled in;
# .env.example is the shareable template)
.env
*.key

# Python
__pycache__/
*.pyc
.pytest_cache/
.venv/
venv/

# Test coverage artifacts (regenerated by `pytest --cov`, never commit)
.coverage
coverage.xml
htmlcov/

# Editor/tool config that shouldn't leak from Production
.claude/
